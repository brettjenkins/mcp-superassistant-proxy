{
  "name": "@leeroy/mcp-superassistant-proxy",
  "version": "0.1.0",
  "description": "A bulletproof proxy server for MCP (Model Context Protocol) that aggregates multiple MCP servers with comprehensive memory leak prevention and reliable HTTP/SSE transport",
  "private": false,
  "keywords": [
    "mcp",
    "stdio",
    "sse",
    "http",
    "gateway",
    "proxy",
    "bridge",
    "chrome-extension",
    "memory-safe",
    "bulletproof"
  ],
  "type": "module",
  "bin": {
    "mcp-superassistant-proxy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.19",
    "@types/yargs": "^17.0.33",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
